# ═══════════════════════════════════════════════════════════════
#  RADIUS — Environment Variables (Vercel + Render)
#  Скопируйте: cp .env.example .env
#  Заполните ВСЕ значения перед запуском
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────
# 1. БЭКЕНД (Render — читаются при старте, restart достаточно)
# ───────────────────────────────────────────────────────────────

# Neon PostgreSQL (asyncpg + SSL)
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST.neon.tech/DB?sslmode=require

# Upstash Redis (SSL обязателен — rediss://)
REDIS_URL=rediss://default:PASS@HOST.upstash.io:6379

# 🔐 SECRET_KEY — сгенерируйте: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_64_HEX_CHARS

# 🤖 TELEGRAM_BOT_TOKEN — получите у @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER

# 🌐 CORS_ORIGINS — фронтенд URL + Telegram Web App
#    Пример для Vercel: https://radius-frontend.vercel.app,https://web.telegram.org
#    Замените на ваш реальный URL с Vercel!
CORS_ORIGINS=https://your-frontend.vercel.app,https://web.telegram.org

# Окружение
ENVIRONMENT=production


# ───────────────────────────────────────────────────────────────
# 2. ФРОНТЕНД (Vercel — встраиваются при сборке, нужен Redeploy)
# ───────────────────────────────────────────────────────────────

# 🌍 URL бэкенда на Render (HTTPS + /api/v1)
NEXT_PUBLIC_API_URL=https://radius-backend.onrender.com/api/v1

# 📡 WebSocket URL (wss:// для HTTPS)
NEXT_PUBLIC_WS_URL=wss://radius-backend.onrender.com/api/v1

# 🗺 Ключ Яндекс.Карт — https://developer.tech.yandex.ru/
NEXT_PUBLIC_YANDEX_MAPS_KEY=YOUR_YANDEX_MAPS_API_KEY


# ───────────────────────────────────────────────────────────────
# 3. ДОПОЛНИТЕЛЬНО (опционально)
# ───────────────────────────────────────────────────────────────

# Для Docker Compose локально
DB_PASSWORD=radius_secret_change_me_in_production
