# ═══════════════════════════════════════════════════════════════
#  RADIUS — Environment Variables
#  Скопируйте этот файл:  cp .env.example .env
#  Заполните ВСЕ значения ниже перед первым запуском
# ═══════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────
# 1. БЭКЕНД (читаются при старте контейнера, restart достаточно)
# ───────────────────────────────────────────────────────────────

# PostgreSQL (PostGIS) — меняйте только если настраиваете внешнюю БД
DATABASE_URL=postgresql+asyncpg://radius:radius_secret@db:5432/radius_db

# Redis — меняйте только если настраиваете внешний Redis
REDIS_URL=redis://redis:6379

# 🔐 SECRET_KEY — обязательно сгенерируйте!
#    Команда:  openssl rand -hex 32
#    Минимум 32 символа. Используется для JWT-токенов.
SECRET_KEY=REPLACE_WITH_64_HEX_CHARS_FROM_OPENSSL_RAND_HEX_32

# 🤖 TELEGRAM_BOT_TOKEN — получите у @BotFather
#    Пример:  123456789:AAHxxxxxYOUR_TOKENxxxxx
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER

# 🌐 CORS_ORIGINS — домены, с которых разрешены запросы к API
#    Обязательно добавьте ваш домен и Telegram Web App
#    Формат: через запятую, без пробелов
CORS_ORIGINS=https://your-domain.com,https://web.telegram.org


# ───────────────────────────────────────────────────────────────
# 2. ФРОНТЕНД (встраиваются в код при сборке, нужна ПЕРЕСБОРКА)
# ───────────────────────────────────────────────────────────────

# 🌍 NEXT_PUBLIC_API_URL — URL вашего бэкенда (HTTPS!)
#    ВАЖНО: Telegram Mini App требует HTTPS
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1

# 📡 NEXT_PUBLIC_WS_URL — WebSocket URL (wss:// для HTTPS)
NEXT_PUBLIC_WS_URL=wss://your-domain.com/api/v1

# 🗺 NEXT_PUBLIC_YANDEX_MAPS_KEY — API-ключ Яндекс.Карт
#    Получите: https://developer.tech.yandex.ru/services/
#    Нужен сервис "JavaScript API и HTTP Геокодер"
NEXT_PUBLIC_YANDEX_MAPS_KEY=YOUR_YANDEX_MAPS_API_KEY


# ───────────────────────────────────────────────────────────────
# 3. ДОПОЛНИТЕЛЬНО (опционально, для production)
# ───────────────────────────────────────────────────────────────

# Пароль PostgreSQL (используется в docker-compose.yml)
DB_PASSWORD=radius_secret_change_me_in_production

# Окружение: development | production
ENVIRONMENT=production
